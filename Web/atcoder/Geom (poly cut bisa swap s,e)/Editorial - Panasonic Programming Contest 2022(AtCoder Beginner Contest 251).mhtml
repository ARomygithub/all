r-copy">#include &lt;iostream&gt;
using namespace std;
typedef long long ll;
const ll inf =3D 1e18;

ll n, m, q;
ll x[55], y[55];
ll u[200005], v[200005];
ll Q1[55], Q2[55], R[55];

ll cross(ll p, ll q, ll r, ll s){
  return p*s - q*r;
}

int main(void)
{
  cin &gt;&gt; n;
  for(int i =3D 1; i &lt;=3D n; i++) cin &gt;&gt; x[i] &gt;&gt; y[i];
  x[n+1] =3D x[1], y[n+1] =3D y[1];
  cin &gt;&gt; m;
  for(int i =3D 1; i &lt;=3D m; i++) cin &gt;&gt; u[i] &gt;&gt; v[i];
 =20
  for(int i =3D 1; i &lt;=3D n; i++){
    Q1[i] =3D x[i+1]-x[i], Q2[i] =3D y[i+1]-y[i], R[i] =3D -inf;
    for(int j =3D 1; j &lt;=3D m; j++){
      R[i] =3D max(R[i], cross(x[i+1]-x[i], y[i+1]-y[i], x[i]+u[j], y[i]+v[=
j]));
    }
  }
 =20
  cin &gt;&gt; q;
  ll a, b;
  for(int k =3D 1; k &lt;=3D q; k++){
    cin &gt;&gt; a &gt;&gt; b;
    bool ans =3D true;
    for(int i =3D 1; i &lt;=3D n; i++) if(cross(Q1[i], Q2[i], a, b) &lt; R[=
i]) ans =3D false;
    if(ans) cout &lt;&lt; "Yes" &lt;&lt; "\n";
    else cout &lt;&lt; "No" &lt;&lt; "\n";
  }
 =20
  return 0;
}=20
